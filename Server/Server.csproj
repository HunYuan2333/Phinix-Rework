<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <ProjectGuid>{91DAC5B9-03E6-45DA-A0FD-AAA805ED131D}</ProjectGuid>
    <OutputType>Exe</OutputType>
    <RootNamespace>PhinixServer</RootNamespace>
    <AssemblyName>PhinixServer</AssemblyName>
    <TargetFramework>net10.0</TargetFramework>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="Command.cs" />
    <Compile Include="CommandInterpreter.cs" />
    <Compile Include="Config.cs" />
    <Compile Include="ConfigItemDeserialisationException.cs" />
    <Compile Include="HelpEntry.cs" />
    <Compile Include="Logger.cs" />
    <Compile Include="Server.cs" />
    <Compile Include="Commands\*.cs" />
    <Compile Include="Extensions\FrameworkPipelineLoggingServerExtension.cs" />
    <Compile Include="Extensions\RedPacketServerExtension.cs" />
    <Compile Include="Framework\FrameworkServerPacketDispatcher.cs" />
    <Compile Include="Framework\PhinixFrameworkServer.cs" />
    <Compile Include="Properties\AssemblyInfo.cs" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="Authentication.Server\Authentication.Server.csproj" />
    <ProjectReference Include="..\Extensions\Chat\Contracts\ChatExtension.csproj" />
    <ProjectReference Include="..\Common\Connections\Connections.csproj" />
    <ProjectReference Include="..\Extensions\Trade\Contracts\TradeExtension.csproj" />
    <ProjectReference Include="..\Common\UserManagement\UserManagement.csproj" />
    <ProjectReference Include="UserManagement.Server\UserManagement.Server.csproj" />
    <ProjectReference Include="..\Common\Utils\Utils.csproj" />
    <ProjectReference Include="ServerRuntime\ServerRuntime.csproj" />
  </ItemGroup>

  <ItemGroup>
    <OfficialServerExtensionProject Include="..\Extensions\Chat\Server\ChatExtension.Server.csproj" />
    <OfficialServerExtensionProject Include="..\Extensions\Trade\Server\TradeExtension.Server.csproj" />
  </ItemGroup>

  <Target Name="CopyOfficialServerExtensions" AfterTargets="Build">
    <PropertyGroup>
      <ServerProjectExtensionDir>$(MSBuildProjectDirectory)\Extensions</ServerProjectExtensionDir>
      <ServerOutputExtensionDir>$(OutDir)Extensions</ServerOutputExtensionDir>
    </PropertyGroup>

    <MSBuild
      Projects="@(OfficialServerExtensionProject)"
      Targets="Build"
      Properties="Configuration=$(Configuration);TargetFramework=net10.0" />

    <MSBuild
      Projects="@(OfficialServerExtensionProject)"
      Targets="GetTargetPath"
      Properties="Configuration=$(Configuration);TargetFramework=net10.0">
      <Output TaskParameter="TargetOutputs" ItemName="_OfficialServerExtensionOutput" />
    </MSBuild>

    <MakeDir Directories="$(ServerOutputExtensionDir);$(ServerProjectExtensionDir)" />
    <Copy
      SourceFiles="@(_OfficialServerExtensionOutput)"
      DestinationFolder="$(ServerOutputExtensionDir)"
      SkipUnchangedFiles="true" />
    <Copy
      SourceFiles="@(_OfficialServerExtensionOutput)"
      DestinationFolder="$(ServerProjectExtensionDir)"
      SkipUnchangedFiles="true" />
  </Target>
</Project>
