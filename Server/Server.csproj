<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <ProjectGuid>{91DAC5B9-03E6-45DA-A0FD-AAA805ED131D}</ProjectGuid>
    <OutputType>Exe</OutputType>
    <RootNamespace>PhinixServer</RootNamespace>
    <AssemblyName>PhinixServer</AssemblyName>
    <TargetFramework>net10.0</TargetFramework>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="Command.cs" />
    <Compile Include="CommandInterpreter.cs" />
    <Compile Include="Config.cs" />
    <Compile Include="ConfigItemDeserialisationException.cs" />
    <Compile Include="HelpEntry.cs" />
    <Compile Include="Logger.cs" />
    <Compile Include="Server.cs" />
    <Compile Include="Commands\*.cs" />
    <Compile Include="Extensions\FrameworkPipelineLoggingServerExtension.cs" />
    <Compile Include="Framework\FrameworkServerPacketDispatcher.cs" />
    <Compile Include="Framework\PhinixFrameworkServer.cs" />
    <Compile Include="Properties\AssemblyInfo.cs" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="Authentication.Server\Authentication.Server.csproj" />
    <ProjectReference Include="..\Common\Connections\Connections.csproj" />
    <ProjectReference Include="Connections.Server\Connections.Server.csproj" />
    <ProjectReference Include="..\Common\UserManagement\UserManagement.csproj" />
    <ProjectReference Include="UserManagement.Server\UserManagement.Server.csproj" />
    <ProjectReference Include="..\Common\Utils\Utils.csproj" />
    <ProjectReference Include="ServerRuntime\ServerRuntime.csproj" />
  </ItemGroup>

  <!--
    Build and copy official server extensions after Server build.
    This target handles Build+Copy only — NO ProjectReference, so Server
    has zero compile-time dependency on any extension.
    For production/CI, prefer scripts/build-extensions.sh (-all).
  -->
  <Target Name="CopyOfficialServerExtensions" AfterTargets="Build">
    <!-- Copy extension server DLLs to Extensions/ for runtime loading.
         Solution build compiles these already — we only copy the outputs.
         No ProjectReference, so Server has zero compile-time dep on any extension. -->

    <MakeDir Directories="$(OutDir)Extensions" />

    <!-- Chat Extension Server -->
    <Copy
      SourceFiles="..\Extensions\Chat\Server\bin\$(Configuration)\net10.0\ChatExtension.Server.dll"
      DestinationFolder="$(OutDir)Extensions"
      SkipUnchangedFiles="true"
      Condition="Exists('..\Extensions\Chat\Server\bin\$(Configuration)\net10.0\ChatExtension.Server.dll')" />

    <!-- Trade Extension Server -->
    <Copy
      SourceFiles="..\Extensions\Trade\Server\bin\$(Configuration)\net10.0\TradeExtension.Server.dll"
      DestinationFolder="$(OutDir)Extensions"
      SkipUnchangedFiles="true"
      Condition="Exists('..\Extensions\Trade\Server\bin\$(Configuration)\net10.0\TradeExtension.Server.dll')" />

    <!-- Contracts DLLs (required at runtime for protobuf types) -->
    <Copy
      SourceFiles="..\Extensions\Chat\Contracts\bin\$(Configuration)\net10.0\ChatExtension.dll"
      DestinationFolder="$(OutDir)Extensions"
      SkipUnchangedFiles="true"
      Condition="Exists('..\Extensions\Chat\Contracts\bin\$(Configuration)\net10.0\ChatExtension.dll')" />
    <Copy
      SourceFiles="..\Extensions\Trade\Contracts\bin\$(Configuration)\net10.0\TradeExtension.dll"
      DestinationFolder="$(OutDir)Extensions"
      SkipUnchangedFiles="true"
      Condition="Exists('..\Extensions\Trade\Contracts\bin\$(Configuration)\net10.0\TradeExtension.dll')" />
  </Target>

</Project>
