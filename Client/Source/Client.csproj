    <ItemGroup>
      <AboutResource Include="$(SolutionDir)\Client\About\**\*.*" />
      <DefsResource Include="$(SolutionDir)\Client\Defs\**\*.*" />
      <LanguagesResource Include="$(SolutionDir)\Client\Languages\**\*.*" />
      <TexturesResource Include="$(SolutionDir)\Client\Textures\**\*.*" />
