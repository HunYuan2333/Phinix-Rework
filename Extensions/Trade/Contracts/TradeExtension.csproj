<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <ProjectGuid>{D1C9486E-43DA-4816-BA8C-EC7C0F233C2C}</ProjectGuid>
    <OutputType>Library</OutputType>
    <RootNamespace>Phinix.TradeExtension</RootNamespace>
    <AssemblyName>TradeExtension</AssemblyName>
    <TargetFrameworks>net472;net10.0</TargetFrameworks>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\Client\ClientExtensionAbstractions\ClientExtensionAbstractions.csproj" Condition="'$(TargetFramework)' == 'net472'" />
    <ProjectReference Include="..\..\..\Common\UserManagement\UserManagement.csproj" />
    <ProjectReference Include="..\..\..\Common\Utils\Utils.csproj" />
  </ItemGroup>
  <Choose>
    <When Condition="Exists('$(SolutionDir)\GameDlls\1.6')">
      <ItemGroup Condition="'$(TargetFramework)' == 'net472'">
        <Reference Include="Assembly-CSharp">
          <HintPath>$(SolutionDir)\GameDlls\1.6\Assembly-CSharp.dll</HintPath>
        </Reference>
        <Reference Include="UnityEngine">
          <HintPath>$(SolutionDir)\GameDlls\1.6\UnityEngine.dll</HintPath>
        </Reference>
      </ItemGroup>
    </When>
    <Otherwise>
      <ItemGroup Condition="'$(TargetFramework)' == 'net472'">
        <Reference Include="Assembly-CSharp">
          <HintPath>..\..\..\GameDlls\Assembly-CSharp.dll</HintPath>
        </Reference>
        <Reference Include="UnityEngine">
          <HintPath>..\..\..\GameDlls\UnityEngine.dll</HintPath>
        </Reference>
      </ItemGroup>
    </Otherwise>
  </Choose>

  <Target Name="CopyToClientExtensions" AfterTargets="Build" Condition="'$(TargetFramework)' == 'net472'">
    <MakeDir Directories="$(SolutionDir)\Output\Client\Common\Extensions" />
    <Copy SourceFiles="$(TargetDir)$(AssemblyName).dll" DestinationFiles="$(SolutionDir)\Output\Client\Common\Extensions\09-TradeExtension.dll" />
  </Target>
</Project>
