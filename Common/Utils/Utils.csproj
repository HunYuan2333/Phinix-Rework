<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <ProjectGuid>{B6FF1583-C75A-42C1-9B75-2B16215A0CF7}</ProjectGuid>
    <OutputType>Library</OutputType>
    <RootNamespace>Utils</RootNamespace>
    <AssemblyName>Utils</AssemblyName>
    <TargetFrameworks>net472;net10.0</TargetFrameworks>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Dependencies\protobuf\csharp\src\Google.Protobuf\Google.Protobuf.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="Framework\Proto\Shared\*.proto" />
    <Content Include="Framework\Proto\Message\FrameworkMessagePacket.proto" />
    <Content Include="Framework\Proto\Command\*.proto" />
    <Content Include="Framework\Proto\Item\*.proto" />
  </ItemGroup>

  <ItemGroup>
    <None Include="compile-proto.bat" />
    <None Include="compile-proto.sh" />
    <None Include="packages.config" />
  </ItemGroup>

  <Target Name="BeforeBuild" Condition="'$(OS)' == 'Windows_NT' and Exists('$(MSBuildProjectDirectory)\compile-proto.bat')">
    <Exec Command="call &quot;$(MSBuildProjectDirectory)\compile-proto.bat&quot;" />
  </Target>
</Project>
